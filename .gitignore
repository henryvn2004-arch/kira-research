.env.*.local

# Editor
.idea/
.vscode/
*.swp

# Claude Code per-machine overrides (settings.json itself IS committed
# so the cron allowlist travels — only the local override file is ignored)
.claude/settings.local.json

# Batch report PDFs — uploaded to Supabase Storage (reports-pdfs bucket) as
# source of truth. Keeping copies in the public repo would (a) bloat the
# repo by ~1.8 MB per topic, (b) let anyone with the raw.githubusercontent
# URL download the paid PDF without authentication. HTML siblings stay
# tracked as searchable archival artifacts.
skills/kira-research-report/outputs/batch/*/*.pdf
