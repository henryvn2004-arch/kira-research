{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/report.html",
      "destination": "/en/custom-research/?from=market-analysis",
      "permanent": true
    },
    {
      "source": "/strategy-builder.html",
      "destination": "/en/custom-research/?from=strategy-builder",
      "permanent": true
    },
    {
      "source": "/docreport.html",
      "destination": "/en/custom-research/?from=doc-intelligence",
      "permanent": true
    },
    {
      "source": "/studio",
      "destination": "/en/custom-research/?from=studio",
      "permanent": true
    },
    {
      "source": "/studio/:path*",
      "destination": "/en/custom-research/?from=studio",
      "permanent": true
    },
    {
      "source": "/library.html",
      "destination": "/en/library",
      "permanent": true
    },
    {
      "source": "/about.html",
      "destination": "/en/about",
      "permanent": true
    },
    {
      "source": "/methodology.html",
      "destination": "/en/methodology",
      "permanent": true
    },
    {
      "source": "/pricing.html",
      "destination": "/en/pricing",
      "permanent": true
    },
    {
      "source": "/insights.html",
      "destination": "/en/insights/",
      "permanent": true
    },
    {
      "source": "/contact.html",
      "destination": "/en/custom-research/",
      "permanent": true
    },
    {
      "source": "/compare.html",
      "destination": "/en/pricing",
      "permanent": true
    },
    {
      "source": "/admin.html",
      "destination": "/en/admin/leads",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },

    { "source": "/en/reports/:slug([a-z0-9][a-z0-9-]+)", "destination": "/en/reports/_view.html" },
    { "source": "/ja/reports/:slug([a-z0-9][a-z0-9-]+)", "destination": "/en/reports/_view.html" },
    { "source": "/ko/reports/:slug([a-z0-9][a-z0-9-]+)", "destination": "/en/reports/_view.html" },

    { "source": "/en/insights/:slug([a-z0-9][a-z0-9-]+)", "destination": "/en/insights/_view.html" },
    { "source": "/ja/insights/:slug([a-z0-9][a-z0-9-]+)", "destination": "/en/insights/_view.html" },
    { "source": "/ko/insights/:slug([a-z0-9][a-z0-9-]+)", "destination": "/en/insights/_view.html" }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  }
}
