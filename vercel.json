{
  "redirects": [
    {
      "source": "/report.html",
      "destination": "/en/custom-research/?from=market-analysis",
      "permanent": true
    },
    {
      "source": "/strategy-builder.html",
      "destination": "/en/custom-research/?from=strategy-builder",
      "permanent": true
    },
    {
      "source": "/docreport.html",
      "destination": "/en/custom-research/?from=doc-intelligence",
      "permanent": true
    },
    {
      "source": "/studio",
      "destination": "/en/custom-research/?from=studio",
      "permanent": true
    },
    {
      "source": "/studio/:path*",
      "destination": "/en/custom-research/?from=studio",
      "permanent": true
    },
    {
      "source": "/library.html",
      "destination": "/en/library",
      "permanent": true
    },
    {
      "source": "/about.html",
      "destination": "/en/about",
      "permanent": true
    },
    {
      "source": "/methodology.html",
      "destination": "/en/methodology",
      "permanent": true
    },
    {
      "source": "/pricing.html",
      "destination": "/en/pricing",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  }
}
