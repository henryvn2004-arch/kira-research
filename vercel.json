{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/report",
      "destination": "/en/custom-research/market-analysis/",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": true
    },
    {
      "source": "/strategy-builder",
      "destination": "/en/custom-research/strategy-builder/",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": true
    },
    {
      "source": "/docreport",
      "destination": "/en/custom-research/?from=doc-intelligence",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": true
    },
    {
      "source": "/library",
      "destination": "/en/library",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/en/about",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": true
    },
    {
      "source": "/methodology",
      "destination": "/en/methodology",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": true
    },
    {
      "source": "/pricing",
      "destination": "/en/pricing",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": true
    },
    {
      "source": "/insights",
      "destination": "/en/insights/",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "/en/custom-research/",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": true
    },
    {
      "source": "/compare",
      "destination": "/en/pricing",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": true
    },
    {
      "source": "/admin",
      "destination": "/en/admin/",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": false
    },
    {
      "source": "/profile",
      "destination": "/en/profile",
      "missing": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },

    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "studio.kiraresearch.com" }],
      "destination": "/studio/:path*"
    },

    { "source": "/sitemap.xml",     "destination": "/api/sitemap" },
    { "source": "/sitemap-en.xml",  "destination": "/api/sitemap?locale=en" },
    { "source": "/sitemap-ja.xml",  "destination": "/api/sitemap?locale=ja" },
    { "source": "/sitemap-ko.xml",  "destination": "/api/sitemap?locale=ko" },

    { "source": "/en/reports/:slug", "destination": "/en/reports/_view" },
    { "source": "/ja/reports/:slug", "destination": "/en/reports/_view" },
    { "source": "/ko/reports/:slug", "destination": "/en/reports/_view" },

    { "source": "/en/insights/:slug", "destination": "/en/insights/_view" },
    { "source": "/ja/insights/:slug", "destination": "/en/insights/_view" },
    { "source": "/ko/insights/:slug", "destination": "/en/insights/_view" },

    { "source": "/ja/companies/vn/", "destination": "/en/companies/vn/" },
    { "source": "/ko/companies/vn/", "destination": "/en/companies/vn/" },
    { "source": "/en/companies/:country/:slug", "destination": "/en/companies/vn/_view" },
    { "source": "/ja/companies/:country/:slug", "destination": "/en/companies/vn/_view" },
    { "source": "/ko/companies/:country/:slug", "destination": "/en/companies/vn/_view" }
  ],
  "functions": {
    "api/inngest.js": {
      "maxDuration": 300,
      "includeFiles": "skills/kira-research-report/templates/*"
    },
    "api/*.js": {
      "maxDuration": 60,
      "includeFiles": "skills/kira-research-report/templates/*"
    }
  },
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/locales/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(.*).(woff2|woff|ttf|otf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon.svg|favicon.ico|favicon-16.png|favicon-32.png|apple-touch-icon.png|icon-512.png|logo.png|site.webmanifest)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, s-maxage=2592000" }
      ]
    }
  ]
}
