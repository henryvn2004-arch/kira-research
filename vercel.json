{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/report",
      "destination": "/en/custom-research/?from=market-analysis",
      "permanent": true
    },
    {
      "source": "/strategy-builder",
      "destination": "/en/custom-research/?from=strategy-builder",
      "permanent": true
    },
    {
      "source": "/docreport",
      "destination": "/en/custom-research/?from=doc-intelligence",
      "permanent": true
    },
    {
      "source": "/studio",
      "destination": "/en/custom-research/?from=studio",
      "permanent": true
    },
    {
      "source": "/studio/:path*",
      "destination": "/en/custom-research/?from=studio",
      "permanent": true
    },
    {
      "source": "/library",
      "destination": "/en/library",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/en/about",
      "permanent": true
    },
    {
      "source": "/methodology",
      "destination": "/en/methodology",
      "permanent": true
    },
    {
      "source": "/pricing",
      "destination": "/en/pricing",
      "permanent": true
    },
    {
      "source": "/insights",
      "destination": "/en/insights/",
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "/en/custom-research/",
      "permanent": true
    },
    {
      "source": "/compare",
      "destination": "/en/pricing",
      "permanent": true
    },
    {
      "source": "/admin",
      "destination": "/en/admin/leads",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },

    { "source": "/en/reports/:slug", "destination": "/en/reports/_view" },
    { "source": "/ja/reports/:slug", "destination": "/en/reports/_view" },
    { "source": "/ko/reports/:slug", "destination": "/en/reports/_view" },

    { "source": "/en/insights/:slug", "destination": "/en/insights/_view" },
    { "source": "/ja/insights/:slug", "destination": "/en/insights/_view" },
    { "source": "/ko/insights/:slug", "destination": "/en/insights/_view" }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  }
}
